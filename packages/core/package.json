{
  "name": "@vibe-flags/core",
  "version": "0.1.18",
  "type": "module",
  "main": "./dist/vibe-flags.js",
  "module": "./dist/vibe-flags.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vibe-flags.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./cdn": "./dist/vibe-flags.cdn.mjs",
    "./cdn/iife": "./dist/vibe-flags.cdn.js"
  },
  "unpkg": "./dist/vibe-flags.cdn.mjs",
  "jsdelivr": "./dist/vibe-flags.cdn.mjs",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": true,
  "peerDependencies": {
    "lit": "^3.0.0 || ^4.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^29.0.1",
    "lit": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite build --config vite.cdn.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "cp ../../README.md ./README.md && pnpm build"
  }
}
